# ── Binance ──────────────────────────────────────────────
# Either raw keys (dev) or AES-256-GCM encrypted (prod, *_ENC)
BINANCE_API_KEY=
BINANCE_API_SECRET=
# BINANCE_API_KEY_ENC=iv:tag:data
# BINANCE_API_SECRET_ENC=iv:tag:data
BINANCE_TESTNET=true

# ── Encryption (64 hex chars = 32 bytes for AES-256) ─────
ENCRYPTION_KEY=

# ── ML service ───────────────────────────────────────────
ML_SERVICE_URL=http://ml:8000
ML_MIN_CONFIDENCE=0.6

# ── Ensemble / strategy ──────────────────────────────────
ENTRY_THRESHOLD=65
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
TIMEFRAME=1h
LOOP_INTERVAL_MS=30000

# ── Infra ────────────────────────────────────────────────
DATABASE_URL=postgres://quad:quad@postgres:5432/quad
REDIS_URL=redis://redis:6379
