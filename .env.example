# ════════════════════════════════════════════════════════════════════
# QUANTUM MIND — Environment Variables
# ════════════════════════════════════════════════════════════════════
#
# IMPORTANT: This frontend uses a Cloudflare Worker proxy for AI calls,
# so NO secrets are needed on the frontend!
# All API keys live inside the Worker or are entered by the user via
# the in-app Settings page (Binance keys → browser localStorage).
#
# Leave this file empty for frontend-only deploy.
# Below variables are ONLY needed if you also deploy the backend (Express server).

# ─── Frontend (Vite) — OPTIONAL ─────────────────────────────────────
# If you DON'T use the Cloudflare Worker and want to call Groq directly:
# VITE_GROQ_API_KEY=

# ─── Backend (Express server) — only if deploying jarvis-server/ ────
# GROQ_API_KEY=
# BINANCE_API_KEY=
# BINANCE_SECRET=
# BINANCE_TESTNET=true
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# HF_TOKEN=
# ENCRYPTION_KEY=
# WEBHOOK_SECRET=
# FRONTEND_URL=
# NODE_ENV=production
