# ════════════════════════════════════════════════════════════════════
# QUANTUM MIND BACKEND — Environment Variables
# Copy this to .env locally OR set these in Render → Environment tab
# ════════════════════════════════════════════════════════════════════

# ─── BINANCE (REQUIRED for real trading) ────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_api_secret_here
# Set to "true" for Binance Testnet (sandbox, no real money)
# Get free testnet keys: https://testnet.binance.vision (GitHub login)
BINANCE_TESTNET=true

# ─── JARVIS AI BRAIN ────────────────────────────────────────────────
# Cloudflare Worker proxy URL (handles Groq/Gemini/SambaNova fallback)
# Leave the default if using the shared worker
JARVIS_WORKER_URL=https://quantum-mind.mohammadfaruki2008.workers.dev/

# ─── SUPABASE (OPTIONAL — for self-learning memory) ─────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── SECURITY ───────────────────────────────────────────────────────
# Random string for TradingView webhook authentication
WEBHOOK_SECRET=change_this_to_random_string

# Admin auth for the API endpoints (frontend sends this in X-Admin-Token header)
ADMIN_TOKEN=change_this_to_random_string

# ─── SERVER ─────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
# Your Netlify/Render frontend URL (for CORS)
FRONTEND_URL=*

# ─── AUTONOMOUS MONITOR ─────────────────────────────────────────────
# Comma-separated coins to monitor 24/7
MONITOR_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
# How often to scan (minutes)
MONITOR_INTERVAL_MIN=15
# Auto-start monitor on server boot
MONITOR_AUTOSTART=true
