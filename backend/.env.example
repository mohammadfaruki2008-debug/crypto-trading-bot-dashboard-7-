###############################################################################
# Quantum Mind Backend — Environment Variables
# Copy to .env for local dev, or paste into Render Dashboard → Environment.
# NEVER commit the real .env file.
###############################################################################

# ─── BINANCE (REQUIRED) ─────────────────────────────────────────────
# Get from: https://www.binance.com/en/my/settings/api-management
# Permissions: ✅ Enable Spot Trading,  ❌ Disable Withdrawals
# Whitelist Render's outbound IPs in Binance API settings
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_here

# Set to "true" for sandbox (free virtual funds from testnet.binance.vision)
BINANCE_TESTNET=true

# ─── JARVIS AI BRAIN (REQUIRED) ─────────────────────────────────────
# Cloudflare Worker proxy that fans out to Groq/Gemini/SambaNova
JARVIS_WORKER_URL=https://quantum-mind.mohammadfaruki2008.workers.dev/

# ─── AUTH (REQUIRED) ────────────────────────────────────────────────
# Random string. The frontend sends this as X-Admin-Token on every API call.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=replace_with_64_char_random_hex_string

# Secret for TradingView webhook validation
WEBHOOK_SECRET=replace_with_random_string

# AES-256-GCM master key for encrypting Binance keys at rest in DB.
# CRITICAL: changing this invalidates all previously saved keys.
# Generate once: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_ENCRYPTION_KEY=replace_with_64_char_random_hex_string

# ─── CORS / FRONTEND (REQUIRED) ─────────────────────────────────────
# Exact URL of your deployed frontend (no trailing slash). Use "*" only for dev.
FRONTEND_URL=https://quantum-mind-frontend.onrender.com

# ─── SUPABASE (OPTIONAL — self-learning memory) ─────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── 24/7 MONITOR (REQUIRED) ────────────────────────────────────────
# Comma-separated symbols to scan continuously
MONITOR_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# How often the monitor wakes up (seconds). 60 = once per minute.
MONITOR_INTERVAL_SEC=60

# Start the monitor automatically when the server boots
MONITOR_AUTOSTART=true

# ─── SERVER (auto-set by Render) ────────────────────────────────────
PORT=8080
NODE_ENV=production
