# ════════════════════════════════════════════════════════════════════
# QUANTUM MIND BACKEND — Environment Variables
# Copy to .env locally, or set in Render.com → Environment tab
# ════════════════════════════════════════════════════════════════════

# ─── 1. AI BRAIN (REQUIRED) ─────────────────────────────────────────
# Get free key: https://console.groq.com/keys
# Used by JARVIS for LLM reasoning (llama-3.3-70b-versatile)
GROQ_API_KEY=gsk_your_groq_key_here


# ─── 2. BINANCE TRADING (REQUIRED for real trades) ──────────────────
# Get from: https://www.binance.com/en/my/settings/api-management
# Permissions: Enable "Spot & Margin Trading", whitelist your server IP
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_api_secret

# Set to "true" to use Binance Testnet (free sandbox, no real money)
# Testnet keys from: https://testnet.binance.vision (login with GitHub)
BINANCE_TESTNET=false


# ─── 3. SUPABASE (OPTIONAL — for RAG memory/knowledge base) ─────────
# Get from: https://supabase.com/dashboard → Project Settings → API
# Skip if you don't want self-learning memory
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...your_anon_key


# ─── 4. SERVER CONFIG ───────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# CORS — your Netlify frontend URL (so it can call this backend)
FRONTEND_URL=https://quantum-mind.netlify.app


# ─── 5. SECURITY ────────────────────────────────────────────────────
# 64-char hex string for AES-256-GCM at-rest encryption
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=64_character_hex_string_here_use_node_crypto_randomBytes_32

# Secret to validate incoming webhooks from TradingView
WEBHOOK_SECRET=your_random_webhook_secret_string


# ─── 6. OPTIONAL EXTRAS ─────────────────────────────────────────────
# Gmail IMAP (if you want email alert scraping — needs TV Pro+)
EMAIL_ACCOUNT=
EMAIL_PASSWORD=

# Hugging Face token (alternative embeddings — optional)
HF_TOKEN=
